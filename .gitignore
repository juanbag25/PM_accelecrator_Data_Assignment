# --- Data ---
# Raw Kaggle CSV is heavy and reproducible via download — never commit it.
data/raw/*
!data/raw/.gitkeep
# Processed parquet is regenerated by the pipeline.
data/processed/*
!data/processed/.gitkeep

# --- Models (heavy binaries) — keep folder, ignore artifacts ---
models/*
!models/.gitkeep

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# --- Jupyter / tooling ---
.python-version

# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# NOTE: reports/figures/ and reports/metrics/ ARE tracked on purpose —
# they are lightweight deliverables (PNGs, JSON metrics).
